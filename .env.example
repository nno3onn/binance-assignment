# Application
APP_ENV=local
LOG_LEVEL=info
TZ=UTC

# Binance
BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
SYMBOLS=BTCUSDT,ETHUSDT
CANDLE_INTERVAL=1m
INITIAL_BACKFILL_HOURS=24

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_BASE_URL=http://localhost:8000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SSE_URL=http://localhost:8000/stream

# Database
POSTGRES_USER=binance
POSTGRES_PASSWORD=binance
POSTGRES_DB=binance_assignment
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://binance:binance@postgres:5432/binance_assignment
