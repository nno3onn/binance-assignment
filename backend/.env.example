# Backend local process configuration
APP_ENV=local
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_REST_TIMEOUT_SECONDS=10
BINANCE_REST_RETRY_COUNT=3
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
BINANCE_WS_KEEPALIVE_SECONDS=30
BINANCE_WS_RETRY_COUNT=3
SYMBOLS=BTCUSDT,ETHUSDT
CANDLE_INTERVAL=1m
INITIAL_BACKFILL_HOURS=24
DASHBOARD_SSE_INTERVAL_SECONDS=5
DASHBOARD_SSE_HEARTBEAT_SECONDS=15

DATABASE_URL=postgresql://binance:binance@localhost:5432/binance_assignment
